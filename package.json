{
  "name": "hubullu",
  "displayName": "Hubullu",
  "description": "Language support for Hubullu (LexDSL)",
  "version": "0.4.0",
  "publisher": "frodo821",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "url": "https://github.com/frodo821/hubullu-ext"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hubullu",
        "aliases": [
          "Hubullu",
          "LexDSL"
        ],
        "extensions": [
          ".hu"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "hubullu-text",
        "aliases": [
          "Hubullu Text"
        ],
        "extensions": [
          ".hut"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hubullu",
        "scopeName": "source.hubullu",
        "path": "./syntaxes/hubullu.tmLanguage.json"
      },
      {
        "language": "hubullu-text",
        "scopeName": "source.hubullu-text",
        "path": "./syntaxes/hubullu-text.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "hubullu.entryRefDisplay.inlayHint",
        "title": "Hubullu: Show Entry References as Inlay Hints"
      },
      {
        "command": "hubullu.entryRefDisplay.overlay",
        "title": "Hubullu: Show Entry References as Surface Forms"
      },
      {
        "command": "hubullu.entryRefDisplay.off",
        "title": "Hubullu: Hide Entry Reference Forms"
      },
      {
        "command": "hubullu.entryRefDisplay.cycle",
        "title": "Hubullu: Cycle Entry Reference Display"
      },
      {
        "command": "hubullu.restartServer",
        "title": "Hubullu: Restart Language Server"
      },
      {
        "command": "hubullu.compileDictionary",
        "title": "Hubullu: Compile Dictionary"
      },
      {
        "command": "hubullu.openDictionary",
        "title": "Hubullu: Open Dictionary Viewer"
      },
      {
        "command": "hubullu.lintFix",
        "title": "Hubullu: Lint & Fix"
      }
    ],
    "configuration": {
      "title": "Hubullu",
      "properties": {
        "hubullu.serverPath": {
          "type": "string",
          "default": "hubullu",
          "description": "Path to the hubullu binary."
        },
        "hubullu.mainFile": {
          "type": "string",
          "default": "",
          "description": "Path to the main .hu entry point file. If empty, uses main.hu in workspace root."
        },
        "hubullu.entryRefDisplayMode": {
          "type": "string",
          "enum": [
            "inlayHint",
            "overlay",
            "off"
          ],
          "default": "inlayHint",
          "description": "How to display resolved entry reference forms.",
          "enumDescriptions": [
            "Show as inlay hints after the expression",
            "Replace the expression with the surface form",
            "Hide resolved forms"
          ]
        }
      }
    }
  },
  "dependencies": {
    "sql.js": "^1.11.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node && cp node_modules/sql.js/dist/sql-wasm.wasm dist/",
    "watch": "cp node_modules/sql.js/dist/sql-wasm.wasm dist/ && npm run compile -- --sourcemap --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  }
}
